# Auth
APP_PASSWORD=fr24
SESSION_SECRET=change-me-in-prod

# Azure auth
# In Azure (Container Apps with UAMI) set AZURE_CLIENT_ID to the UAMI client id.
# Locally, leave blank and use `az login` — DefaultAzureCredential will pick it up.
AZURE_CLIENT_ID=

# Azure AI Translator (Text Translation v3)
# AAD auth (Managed Identity) is used when AZURE_TRANSLATOR_KEY is empty.
AZURE_TRANSLATOR_ENDPOINT=https://<resource>.cognitiveservices.azure.com
AZURE_TRANSLATOR_REGION=eastus2
AZURE_TRANSLATOR_KEY=

# Azure AI Document Translation (async batch, format-preserving NMT).
# Defaults to AZURE_TRANSLATOR_ENDPOINT if blank.
AZURE_DOC_TRANSLATOR_ENDPOINT=

# Azure AI Foundry (model inference endpoint)
# Format: https://<aif-name>.services.ai.azure.com/models
AZURE_FOUNDRY_ENDPOINT=
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_MODELS=gpt-4o,gpt-4o-mini,phi-3-medium

# Embedding deployment used for back-translation cosine in meaning scoring.
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large-015418
# LLM-as-judge model used for safety scoring.
AZURE_JUDGE_MODEL=gpt-4.1-mini-601090

# Azure Storage (Blob + Table) — accessed via AAD only
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_UPLOADS_CONTAINER=uploads
AZURE_STORAGE_UPLOADS_TABLE=uploads
AZURE_STORAGE_RUNS_TABLE=runs
